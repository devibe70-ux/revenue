generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email        String   @unique @db.VarChar(255)
  baseCurrency String   @default("USD") @map("base_currency") @db.VarChar(3)
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)

  integrations PlatformIntegration[]
  revenues     RevenueRecord[]

  @@map("users")
}

model PlatformIntegration {
  id                    String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId                String    @map("user_id") @db.Uuid
  platformName          String    @map("platform_name") @db.VarChar(50)
  encryptedAccessToken  String    @map("encrypted_access_token") @db.Text
  encryptedRefreshToken String?   @map("encrypted_refresh_token") @db.Text
  tokenExpiresAt        DateTime? @map("token_expires_at") @db.Timestamptz(6)
  status                String    @default("active") @db.VarChar(20)
  createdAt             DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt             DateTime  @default(now()) @map("updated_at") @db.Timestamptz(6)

  user     User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  revenues RevenueRecord[]

  @@map("platform_integrations")
}

model RevenueRecord {
  id                  String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId              String    @map("user_id") @db.Uuid
  integrationId       String?   @map("integration_id") @db.Uuid
  platform            String    @db.VarChar(50)
  streamType          String    @map("stream_type") @db.VarChar(50)
  grossAmount         Decimal   @map("gross_amount") @db.Decimal(15, 4)
  currency            String    @db.VarChar(3)
  exchangeRateToBase  Decimal?  @default(1.000000) @map("exchange_rate_to_base") @db.Decimal(10, 6)
  netSettledAmount    Decimal   @map("net_settled_amount") @db.Decimal(15, 4)
  payoutStatus        String    @map("payout_status") @db.VarChar(20)
  estimatedPayoutDate DateTime? @map("estimated_payout_date") @db.Timestamptz(6)
  timestamp           DateTime  @db.Timestamptz(6)
  createdAt           DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  user        User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  integration PlatformIntegration? @relation(fields: [integrationId], references: [id], onDelete: SetNull)

  @@index([userId, timestamp])
  @@index([platform, payoutStatus])
  @@map("revenue_records")
}
