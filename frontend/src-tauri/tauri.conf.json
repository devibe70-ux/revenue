{
  "build": {
    "beforeDevCommand": "npm run web",
    "beforeBuildCommand": "npx expo export -p web",
    "devPath": "http://localhost:8081",
    "distDir": "../dist"
  },
  "package": {
    "productName": "Unified Revenue Dashboard",
    "version": "1.0.0"
  },
  "tauri": {
    "allowlist": {
      "all": false
    },
    "bundle": {
      "active": true,
      "category": "Finance",
      "copyright": "",
      "icon": [
        "icons/32x32.png",
        "icons/128x128.png",
        "icons/128x128@2x.png",
        "icons/icon.icns",
        "icons/icon.ico"
      ],
      "identifier": "com.revenudashboard.app",
      "targets": ["msix"],
      "windows": {
        "certificateThumbprint": null,
        "digestAlgorithm": "sha256",
        "timestampUrl": ""
      }
    },
    "security": {
      "csp": null
    },
    "windows": [
      {
        "fullscreen": false,
        "height": 800,
        "resizable": true,
        "title": "Revenu Dashboard",
        "width": 1200
      }
    ]
  }
}
